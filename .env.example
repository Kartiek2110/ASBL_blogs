# Copy this file to .env and fill in your credentials
# Then run: source .env && python blog_image_automation.py

# ── WordPress credentials ──────────────────────────────────────────────────────
# Your WordPress username (not email)
export WP_USER="your_wordpress_username"

# WordPress Application Password (NOT your regular password)
# To create one: WP Admin → Users → Edit your profile → Application Passwords → Add New
# Format: xxxx xxxx xxxx xxxx xxxx xxxx  (with spaces is fine)
export WP_APP_PASS="xxxx xxxx xxxx xxxx xxxx xxxx"

# No OpenAI API key needed — the script opens ChatGPT directly in the browser.
# Just make sure you're logged into ChatGPT in Chrome before running.
